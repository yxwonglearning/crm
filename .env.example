APP_NAME="Self Hosted CRM"
NODE_ENV=development
PORT=3000
APP_BASE_URL=http://localhost:3000
AUTH_PROVIDER=local

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=crm_app
DB_PASSWORD=crm_app_password
DB_NAME=crm

JWT_SECRET=change-this-long-random-secret-before-production
JWT_EXPIRES_IN=8h
JWT_REMEMBER_EXPIRES_IN=30d
JWT_ISSUER=self-hosted-crm
JWT_AUDIENCE=self-hosted-crm-users

# Clerk migration. Set AUTH_PROVIDER=clerk after mapping local users to Clerk IDs.
CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_JWT_KEY=
CLERK_AUTHORIZED_PARTIES=http://localhost:3000
CLERK_AUTO_LINK_BY_EMAIL=false

ADMIN_NAME=System Admin
ADMIN_EMAIL=your-admin-email@example.com
ADMIN_PASSWORD=replace-with-a-strong-admin-password
